{
  "manifest_version": 3,
  "name": "TubeDL",
  "description": "Send the current YouTube page to the TubeDL desktop app.",
  "version": "0.1.0",
  "action": {
    "default_title": "TubeDL",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://youtube.com/watch*",
        "https://m.youtube.com/watch*"
      ],
      "js": [
        "youtube-content.js"
      ],
      "css": [
        "youtube-content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "http://127.0.0.1:17335/*",
    "http://localhost:17335/*"
  ]
}
