{
  "name": "ytmp3",
  "version": "0.1.0",
  "description": "Simple YouTube downloader for MP3 and MP4 formats.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [
    "youtube",
    "downloader",
    "mp3",
    "mp4"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.local.ytmp3",
    "productName": "YTMP3",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "bin/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "bin/**"
    ]
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
